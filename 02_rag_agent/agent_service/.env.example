RAG_SERVICE_URL=http://localhost:8001
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Бенчмарк 01_retrieval_eval: titles α=1.0, chunks α=0.7 (см. EXPERIMENTS.md)
HYBRID_ALPHA_TITLES=1.0
HYBRID_ALPHA_CHUNKS=0.7

# Tool result spill → agent_workspace (Hermes layer 2)
TOOL_PERSIST_THRESHOLD_CHARS=8000
TOOL_PERSIST_PREVIEW_CHARS=2000
OPEN_ARTICLE_PREVIEW_LINES=80
WORKSPACE_READ_PAGE_LINES=80

# Dialog history LLM summarization (Hermes ContextCompressor)
CONTEXT_COMPRESS_ENABLED=true
CONTEXT_COMPRESS_THRESHOLD_CHARS=60000
CONTEXT_COMPRESS_PROTECT_HEAD=2
CONTEXT_COMPRESS_PROTECT_TAIL=10
