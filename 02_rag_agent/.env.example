# PostgreSQL (поднят через docker compose up -d)
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# Ollama (локально)
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=embeddinggemma
EMBED_DIM=768

# LLM API (OpenAI-compatible) — используются LiteLLM
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Эти переменные читает LiteLLM напрямую (совпадают с LLM_API_*)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
