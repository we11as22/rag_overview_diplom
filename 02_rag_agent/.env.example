# =============================================================
# LLM API (OpenAI-compatible) — оба имени нужны:
#   OPENAI_* читает LiteLLM напрямую
#   LLM_* используются в agent.py как fallback
# =============================================================
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# =============================================================
# Ollama — на хосте для ./start.sh (rag_service локально)
# Для rag_service в Docker compose подставляется OLLAMA_BASE_URL_DOCKER
# =============================================================
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URL_DOCKER=http://host.docker.internal:11434
EMBED_MODEL=embeddinggemma
EMBED_DIM=768

# =============================================================
# PostgreSQL / RAG (локальный start.sh; в Docker compose задаётся в yml)
# =============================================================
# DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
# RAG_SERVICE_URL=http://localhost:8001

# Tool spill + context compression (agent_service, см. agent_service/.env.example)
# TOOL_PERSIST_THRESHOLD_CHARS=8000
# CONTEXT_COMPRESS_ENABLED=true
# CONTEXT_COMPRESS_THRESHOLD_CHARS=60000
